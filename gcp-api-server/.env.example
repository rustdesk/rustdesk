# Server Port (Cloud Run defaults to 8080)
PORT=8080

# Firebase Web API Key (Used to validate user credentials via Identity Toolkit REST API)
# Find this in Project Settings -> General -> Web API Key on Firebase Console
FIREBASE_API_KEY=your_firebase_web_api_key_here

# Firebase Project ID
FIREBASE_PROJECT_ID=cislink-500-takeaway

# (Optional for local development) Path to your Firebase service account JSON key file
# When running on Cloud Run, the application will use Cloud Run's default service account, 
# so you do not need to configure GOOGLE_APPLICATION_CREDENTIALS in production.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
